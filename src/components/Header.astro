---
import Logo from './Logo.astro';

const nav = [
  { href: '/the-lodge', label: 'The Lodge' },
  { href: '/the-cottage', label: 'The Cottage' },
  { href: '/trails', label: 'The Trails' },
  { href: '/#amenities', label: 'Amenities' },
  { href: '/#register', label: 'Register Interest' },
];
---

<header class="absolute top-0 inset-x-0 z-30">
  <div class="container-prose flex items-center justify-between py-6 md:py-8 px-6 md:px-10">
    <Logo />

    <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
      {
        nav.slice(0, -1).map((item) => (
          <a
            href={item.href}
            class="text-sm tracking-wide text-cream-50/80 hover:text-gold-300 transition"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={nav[nav.length - 1].href}
        class="text-sm tracking-wide px-4 py-2 rounded-full border border-gold-400/50 text-gold-300 hover:bg-gold-400 hover:text-forest-950 transition"
      >
        {nav[nav.length - 1].label}
      </a>
    </nav>

    <details class="md:hidden relative">
      <summary
        class="list-none cursor-pointer text-cream-50 p-2 -mr-2"
        aria-label="Open menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <path d="M3 7h18M3 12h18M3 17h18" stroke-linecap="round" />
        </svg>
      </summary>
      <nav
        class="absolute right-0 top-full mt-2 min-w-[220px] rounded-xl border border-cream-50/10 bg-forest-900/95 backdrop-blur p-3 flex flex-col gap-1 shadow-xl"
        aria-label="Mobile"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="px-3 py-2 rounded-lg text-sm text-cream-50/90 hover:bg-forest-800 hover:text-gold-300 transition"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
