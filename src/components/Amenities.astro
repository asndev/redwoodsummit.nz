---
const amenities = [
  {
    title: 'Secure Bike Vault',
    body: 'Purpose-built, locked bike storage. Bring your dream build without a second thought.',
    icon: 'vault',
  },
  {
    title: 'Pro Wash Station',
    body: 'Hose, stands, tools, and lighting. Strip the mud, dial the drivetrain, park it clean.',
    icon: 'wash',
  },
  {
    title: 'Hot Spa Recovery',
    body: 'Outdoor spa and recovery lounge — warm water, forest air, tomorrow’s legs, tonight.',
    icon: 'spa',
  },
  {
    title: 'Sleeps 8+',
    body: 'Designed for crews and teams. Multiple bedrooms, generous living, shared dinners.',
    icon: 'sleep',
  },
  {
    title: 'Forest-framed Views',
    body: 'Wake up to the Redwoods. Floor-to-ceiling glass, canopy light, morning mist.',
    icon: 'forest',
  },
  {
    title: 'Direct Trail Access',
    body: 'Roll from the driveway into Whakarewarewa Forest. No shuttles, no city noise.',
    icon: 'trail',
  },
];

const iconPaths: Record<string, string> = {
  vault: 'M4 10h16v10H4zM8 10V7a4 4 0 1 1 8 0v3M12 14v3',
  wash: 'M4 12c0-4 4-8 8-8s8 4 8 8-4 8-8 8c-3 0-6-2-7-5M4 4v6h6',
  spa: 'M12 3s4 3 4 7c0 2.5-2 4-4 4s-4-1.5-4-4c0-4 4-7 4-7zM4 20c2 1 4 1 6-0.5M14 19.5c2 1.5 4 1.5 6 0.5',
  sleep: 'M3 18V9h6v5h12v4M3 18h18M7 9V6h10v3',
  forest: 'M12 3l-6 8h4l-5 7h14l-5-7h4z M12 3v18',
  trail: 'M3 20c4-4 8-1 12-5s6 0 6 0M3 20l3-3M9 14l3-3',
};
---

<section id="amenities" class="section bg-forest-950 border-t border-cream-50/5">
  <div class="container-prose">
    <div class="max-w-3xl">
      <span class="eyebrow">Every Detail, Built for the Ride</span>
      <h2 class="mt-5 text-4xl md:text-5xl lg:text-6xl text-cream-50">
        Amenities that <span class="italic text-gold-300">earn their place.</span>
      </h2>
      <p class="mt-6 text-lg text-cream-50/70 leading-relaxed">
        Not a lodge with a bike rack bolted on — a lodge designed around the ride. From the vault to the spa, every space supports the day before, the day of, and the day after.
      </p>
    </div>

    <ul class="mt-14 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        amenities.map((a) => (
          <li class="group relative p-8 rounded-2xl bg-forest-900/60 border border-cream-50/5 hover:border-gold-400/40 transition">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-forest-800 text-gold-300 border border-gold-400/20">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[a.icon]} />
              </svg>
            </div>
            <h3 class="mt-6 text-xl text-cream-50 font-display">{a.title}</h3>
            <p class="mt-2 text-cream-50/65 leading-relaxed text-sm">{a.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
