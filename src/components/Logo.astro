---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a
  href="/"
  class:list={['group flex items-center gap-2.5 text-cream-50 transition hover:text-gold-300', className]}
  aria-label="Redwood Summit — home"
>
  <svg
    width="28"
    height="28"
    viewBox="0 0 32 32"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="transition-transform group-hover:-translate-y-0.5"
  >
    <path
      d="M16 2 L28 26 H4 Z"
      fill="currentColor"
      opacity="0.15"
    />
    <path
      d="M16 6 L25 24 H7 Z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linejoin="round"
    />
    <path
      d="M16 11 L21 22 H11 Z"
      fill="currentColor"
    />
    <path
      d="M16 2 V30"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      opacity="0.6"
    />
  </svg>
  <span class="flex flex-col leading-none">
    <span class="font-display text-lg tracking-tight">Redwood Summit</span>
    <span class="text-[10px] uppercase tracking-[0.22em] text-gold-400/80 mt-1">Rotorua · NZ</span>
  </span>
</a>
