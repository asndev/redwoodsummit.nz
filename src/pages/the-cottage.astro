---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import RegisterInterest from '../components/RegisterInterest.astro';
import { IMG } from '../images';
import { SITE } from '../consts';

const title = 'Redwood Summit Cottage';
const description = `Redwood Summit Cottage — our family-oriented residence in Rotorua, next to the Redwoods trail network. A calmer retreat with direct forest access. Opening ${SITE.openingYear}.`;

const finalSpecs = [
  ['Style', 'Family-oriented'],
  ['Bedrooms', 'TBD'],
  ['Max guests', 'TBD'],
  ['Setting', 'Redwood Park, Rotorua'],
  ['Opening', `${SITE.openingYear}`],
  ['Rates', 'Inquire for rates and availability'],
];
---

<BaseLayout title={title} description={description}>
  <PageHero
    eyebrow="Family Residence"
    title="A quieter cabin"
    italic="in the same great forest."
    lede="Our second property at Redwood Summit — smaller, warmer, family-scaled. The same direct access to the Whakarewarewa Redwoods; a different pace of stay."
    image={IMG.cottage}
  />

  <section class="section bg-forest-950">
    <div class="container-prose grid md:grid-cols-2 gap-12 md:gap-20 items-start">
      <div>
        <span class="eyebrow">The Idea</span>
        <h2 class="mt-5 text-3xl md:text-5xl text-cream-50">
          Family, forest, <span class="italic text-gold-300">first light.</span>
        </h2>
        <div class="mt-8 space-y-5 text-cream-50/75 leading-relaxed text-lg">
          <p>
            The Cottage is the gentler sibling to the Lodge. Same location, same forest, same access to 180+ km of trails — but designed for families, smaller groups, and the kind of stay where some of you ride and some of you read by the fire.
          </p>
          <p>
            Bring the kids on bikes for the easy Whakarewarewa green trails. Walk the redwoods at sunset. Come home to a warm, timber-lined cottage just loud enough with life to feel like a holiday, and just quiet enough to feel like rest.
          </p>
          <p>
            Full details will be confirmed closer to opening — register your interest for first access.
          </p>
        </div>
      </div>

      <div class="sticky top-10">
        <div class="rounded-2xl overflow-hidden aspect-[4/5]">
          <img src={IMG.forestMorning} alt="Morning in the forest — placeholder" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <dl class="mt-6 rounded-2xl border border-cream-50/10 bg-forest-900/50 p-8 grid grid-cols-2 gap-y-5 gap-x-6">
          {
            finalSpecs.map(([k, v]) => (
              <div>
                <dt class="text-[11px] uppercase tracking-[0.2em] text-cream-50/50">{k}</dt>
                <dd class="mt-1 text-cream-50 font-display text-lg">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <RegisterInterest />
</BaseLayout>
