---
interface Props {
  eyebrow: string;
  title: string;
  italic?: string;
  lede: string;
  sublede?: string;
  image: string;
}
const { eyebrow, title, italic, lede, sublede, image } = Astro.props;
---

<section class="relative isolate min-h-[70svh] flex items-end overflow-hidden pt-32 pb-16 md:pb-24">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url(${image});`}
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-forest-950 via-forest-950/70 to-forest-950/50" />
  </div>
  <div class="container-prose px-6 md:px-10 w-full">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="mt-5 font-display text-4xl md:text-6xl lg:text-7xl text-cream-50 max-w-4xl leading-[1]">
      {title}
      {italic && (<><br /><span class="italic text-gold-300">{italic}</span></>)}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-cream-50/80 leading-relaxed">{lede}</p>
    {sublede && (
      <p class="mt-4 max-w-2xl font-display italic text-lg md:text-xl text-gold-300/90">
        {sublede}
      </p>
    )}
  </div>
</section>
