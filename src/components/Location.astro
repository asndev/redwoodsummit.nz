---
import { IMG } from '../images';

const stats = [
  { n: '180+', l: 'km of trails' },
  { n: '130+', l: 'named runs' },
  { n: 'On your', l: 'doorstep' },
  { n: 'Host of', l: 'Crankworx Rotorua' },
];
---

<section id="trails" class="relative isolate section overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url(${IMG.forestTrail});`}
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-forest-950/95 via-forest-950/85 to-forest-950/70" />
  </div>

  <div class="container-prose">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <span class="eyebrow">The Trails</span>
        <h2 class="mt-5 text-4xl md:text-5xl lg:text-6xl text-cream-50">
          Whakarewarewa. <span class="italic text-gold-300">The Redwoods.</span>
        </h2>
        <div class="mt-8 space-y-5 text-cream-50/80 leading-relaxed text-lg">
          <p>
            Known locally as "the Redwoods," Whakarewarewa Forest is regularly ranked among the best mountain biking destinations on earth. Loamy volcanic soil, towering Californian redwoods planted over a century ago, and a trail network built by riders, for riders.
          </p>
          <p>
            From flowy green descents to world-cup gnarly black lines, everything a rider wants is within pedaling distance of the door. Rotorua is also the host city of Crankworx — the pilgrimage for every serious MTB enthusiast.
          </p>
        </div>
        <a href="/trails" class="mt-8 btn-secondary">
          Discover the trail network
        </a>
      </div>

      <dl class="grid grid-cols-2 gap-4">
        {
          stats.map((s) => (
            <div class="rounded-2xl border border-cream-50/10 bg-forest-950/60 backdrop-blur-sm p-6 md:p-8">
              <dt class="text-[11px] uppercase tracking-[0.22em] text-cream-50/60">{s.l}</dt>
              <dd class="mt-3 font-display text-3xl md:text-5xl text-gold-300">{s.n}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>
