---
import Logo from './Logo.astro';
import { SITE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-cream-50/10 bg-forest-950">
  <div class="container-prose px-6 md:px-10 py-16 grid gap-12 md:grid-cols-[1.3fr_1fr_1fr]">
    <div>
      <Logo />
      <p class="mt-5 text-sm text-cream-50/60 max-w-sm leading-relaxed">
        A premium mountain bike lodge in Rotorua, New Zealand — directly next to the Whakarewarewa Redwoods trail network. Opening {SITE.openingYear}.
      </p>
    </div>

    <div>
      <h4 class="text-sm font-medium text-gold-300 tracking-wide uppercase">Explore</h4>
      <ul class="mt-4 space-y-2 text-sm text-cream-50/70">
        <li><a href="/lodge" class="hover:text-gold-300 transition">The Lodge</a></li>
        <li><a href="/cottage" class="hover:text-gold-300 transition">The Cottage</a></li>
        <li><a href="/trails" class="hover:text-gold-300 transition">The Trails</a></li>
        <li><a href="/#amenities" class="hover:text-gold-300 transition">Amenities</a></li>
        <li><a href="/#faq" class="hover:text-gold-300 transition">FAQ</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-medium text-gold-300 tracking-wide uppercase">Stay in the Loop</h4>
      <p class="mt-4 text-sm text-cream-50/70 leading-relaxed">
        Bookings open in {SITE.openingYear}. Register your interest to be the first notified — direct-booking priority ahead of public listings.
      </p>
      <a
        href={`mailto:${SITE.mailto}?subject=${encodeURIComponent('Register Interest — Redwood Summit')}&body=${encodeURIComponent("Kia ora,\n\nI'd like to register my interest in staying at Redwood Summit. Please notify me when bookings open.\n\nPreferred dates (if known):\nGroup size:\nRiding level:\n\nThanks!")}`}
        class="mt-4 inline-flex items-center gap-2 text-sm text-gold-300 hover:text-gold-400 transition"
      >
        {SITE.mailto}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
  </div>

  <div class="border-t border-cream-50/10">
    <div class="container-prose px-6 md:px-10 py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-cream-50/50">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <nav class="flex items-center gap-5" aria-label="Legal">
        <a href="/privacy" class="hover:text-gold-300 transition">Privacy</a>
        <a href="/terms" class="hover:text-gold-300 transition">Terms</a>
        <span class="text-cream-50/30">·</span>
        <span>Rotorua · Aotearoa NZ</span>
      </nav>
    </div>
  </div>
</footer>
